# 禁止在 uploads 目录执行任何脚本
<IfModule mod_php.c>
    php_flag engine off
</IfModule>

# 禁止访问 .htaccess 本身
<FilesMatch "^\.htaccess">
    Order allow,deny
    Deny from all
</FilesMatch>

# 如果上传了 PHP 等脚本，直接返回 403
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule \.(php|php3|php4|php5|phtml|pl|py|jsp|asp|aspx|cgi|sh|bash)$ - [F,L]
</IfModule>

# Send the right Content-Type for the formats we actually serve.
# Apache's default mime.types is missing webp / avif on most distros,
# and a blanket `ForceType application/octet-stream` (which used to be
# here) breaks <img> rendering and treats every download as binary.
# Script extensions (.php / .pl / .py / etc.) are already 403'd by the
# RewriteRule above, so we don't need ForceType as a backstop.
<IfModule mod_mime.c>
    AddType image/jpeg  .jpg .jpeg
    AddType image/png   .png
    AddType image/gif   .gif
    AddType image/webp  .webp
    AddType image/avif  .avif
    AddType image/apng  .apng
    AddType image/svg+xml .svg
    AddType image/bmp   .bmp
    AddType image/tiff  .tif .tiff
    AddType image/x-icon .ico
</IfModule>
