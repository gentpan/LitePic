# ==========================
# LitePic - 环境配置模板
# 复制此文件为 .env 并填入实际值
# ==========================

# 站点基础配置
SITE_NAME="LitePic"
SITE_DESCRIPTION="轻量级图床程序"
SITE_URL=""

# 上传限制（MB）
MAX_FILE_SIZE_MB=20
# 允许上传的图片格式（逗号分隔；默认全部支持）
UPLOAD_ALLOWED_TYPES=jpg,jpeg,png,gif,webp,avif,heic,heif,ico,svg,bmp,tiff,tif

# 管理员 API Key（必须修改！建议使用强随机字符串）
ADMIN_API_KEY=""

# Cookie 安全（HTTPS 站点建议设为 true）
COOKIE_SECURE=false

# 自动处理开关
AUTO_COMPRESS_ON_UPLOAD=false
AUTO_CONVERT_ON_UPLOAD=false
AUTO_CONVERT_WEBP_ON_UPLOAD=false
AUTO_CONVERT_AVIF_ON_UPLOAD=false
CONVERT_PREFERRED_FORMAT=webp
KEEP_ORIGINAL_AFTER_PROCESS=false
COMPRESSION_MODE=imagemagick

# 水印（水印会写入新上传/导入/转换后的最终文件）
WATERMARK_ENABLED=false
WATERMARK_TYPE=text
WATERMARK_TEXT="LitePic"
WATERMARK_POSITION=bottom-right
WATERMARK_OPACITY=100
WATERMARK_FONT_SIZE=18
WATERMARK_MARGIN=18
WATERMARK_COLOR="#ffffff"
# 默认会优先尝试服务器上的 Ubuntu 字体；中文水印建议上传或填写 TTF/OTF 字体路径
WATERMARK_FONT_PATH=""
WATERMARK_IMAGE_PATH=""
WATERMARK_IMAGE_WIDTH=160
WATERMARK_PANEL_ENABLED=true
WATERMARK_PANEL_OPACITY=34
WATERMARK_PANEL_PADDING=10
WATERMARK_PANEL_RADIUS=10

# PHP 受控防盗链入口（手动开启后新生成图片地址使用 /i/...；后台开关默认使用 .htaccess 保持 /uploads/... 原路径）
HOTLINK_PROTECTION_ENABLED=false
HOTLINK_ALLOWED_DOMAINS=""
HOTLINK_ALLOW_EMPTY_REFERER=true

# 第三方上传 API Key（逗号分隔，可选）
THIRD_PARTY_API_KEYS=""

# TinyPNG 压缩 API Key（逗号分隔，可选）
TINIFY_API_KEYS=""

# 远程存储配置（S3 兼容协议，Cloudflare R2 / AWS S3 通用）
# 填完整 Bucket / Endpoint / Key / Secret 后自动实时同步；本地删除后远程对象默认 24 小时后删除
REMOTE_STORAGE_USAGE=backup
S3_BUCKET=""
S3_REGION=auto
S3_ENDPOINT=""
S3_KEY=""
S3_SECRET=""
S3_PATH_PREFIX=uploads
S3_PUBLIC_BASE_URL=""
REMOTE_STORAGE_DELETE_DELAY_SECONDS=86400

# 队列心跳：当没有真正的 cron 时的兜底机制
# 任意 web 请求结束后检查"距上次 drain 超过 N 小时"，是则自动跑一次 worker
# 适合自托管低流量场景（个人图床），跨所有面板/无面板环境通用
# 配了真 cron 也不冲突，flock 互斥确保不会双跑
LITEPIC_HEARTBEAT_DISABLED=false
LITEPIC_HEARTBEAT_INTERVAL_HOURS=24

# CORS 跨域白名单（逗号分隔；* = 允许所有；空 = 禁止跨域）
CORS_ALLOWED_ORIGINS=*

# 调试模式（生产环境必须设为 false）
DEBUG=false
DISPLAY_ERRORS=false
