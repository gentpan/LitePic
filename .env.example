# ==========================
# LitePic - 环境配置模板
# 复制此文件为 .env 并填入实际值
# ==========================

# 站点基础配置
SITE_NAME="LitePic"
SITE_DESCRIPTION="轻量级图床程序"
SITE_URL=""

# 上传限制（MB）
MAX_FILE_SIZE_MB=20

# 管理员 API Key（必须修改！建议使用强随机字符串）
ADMIN_API_KEY=""

# Cookie 安全（HTTPS 站点建议设为 true）
COOKIE_SECURE=false

# 自动处理开关
AUTO_COMPRESS_ON_UPLOAD=false
AUTO_CONVERT_WEBP_ON_UPLOAD=false
COMPRESSION_MODE=hybrid

# 第三方上传 API Key（逗号分隔，可选）
THIRD_PARTY_API_KEYS=""

# TinyPNG 压缩 API Key（逗号分隔，可选）
TINIFY_API_KEYS=""

# 远程存储配置（S3 / Cloudflare R2）
REMOTE_STORAGE_MODE=off
S3_PROVIDER=r2
S3_BUCKET=""
S3_REGION=auto
S3_ENDPOINT=""
S3_KEY=""
S3_SECRET=""
S3_PATH_PREFIX=uploads
S3_PUBLIC_BASE_URL=""

# 调试模式（生产环境必须设为 false）
DEBUG=false
DISPLAY_ERRORS=false
