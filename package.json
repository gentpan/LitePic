{
  "name": "litepic",
  "version": "3.3.7",
  "description": "LitePic - 轻量级自托管图床系统",
  "scripts": {
    "build:css": "npx @tailwindcss/cli -i ./assets/css/tailwind.css -o ./assets/css/main.css --minify",
    "build:css:dev": "npx @tailwindcss/cli -i ./assets/css/tailwind.css -o ./assets/css/main.css",
    "watch:css": "npx @tailwindcss/cli -i ./assets/css/tailwind.css -o ./assets/css/main.css --watch"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gentpan/LitePic.git"
  },
  "keywords": [
    "image-hosting",
    "php",
    "self-hosted"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.4",
    "tailwindcss": "^4.2.4"
  }
}
