RewriteEngine On
DirectorySlash Off

# Modern image MIME types — Apache's default mime.types doesn't ship
# WebP/AVIF on every distro, so static delivery falls back to
# application/octet-stream which breaks <img> rendering and downloads.
<IfModule mod_mime.c>
    AddType image/webp .webp
    AddType image/avif .avif
    AddType image/apng .apng
</IfModule>

# 优先拦截 /api 路径（避免与 api/ 真实目录冲突）
RewriteRule ^api/?$ index.php [QSA,L]
RewriteRule ^api/v1(/.*)?$ index.php [QSA,L]
RewriteRule ^i(/.*)?$ index.php [QSA,L]

# 禁止访问敏感文件和目录
RedirectMatch 403 ^/\.env
RedirectMatch 403 ^/\.git
RedirectMatch 403 ^/data/
RedirectMatch 403 ^/logs/
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

# 禁止在 uploads 目录执行 PHP（即使上传了恶意脚本也无法执行）
<IfModule mod_rewrite.c>
    RewriteRule ^uploads/.*\.php$ - [F,L]

    # 可选：严格防盗链时取消注释，并改成你的域名
    # RewriteCond %{HTTP_REFERER} !^$
    # RewriteCond %{HTTP_REFERER} !^https?://([^/]+\.)?example\.com(/|$) [NC]
    # RewriteRule ^uploads/ - [F,L]
</IfModule>

# 真实文件/目录直接访问（/api 路径除外，需路由到单入口）
RewriteCond %{REQUEST_URI} !^/api/?$
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# 统一单入口无后缀路由
RewriteRule ^$ index.php [QSA,L]
RewriteRule ^(upload|gallery|docs|api|settings|stats)/?$ index.php [QSA,L]
RewriteRule ^i/.*$ index.php [QSA,L]

# 设置子页面路径化 URL（/settings/tasks → settings 主入口 + ?tab=tasks）
# 让浏览器地址栏显示干净的 /settings/<tab> 而不是 ?tab= 查询串
RewriteRule ^settings/([a-z]+)/?$ index.php?tab=$1 [QSA,L]

# 自定义图片 URL 前缀 → 全部走 image.php 做统计 + serve
#
# 用户可以在「设置 → 图片处理 → 图片链接前缀」自由填任意单词 prefix
# （/img/、/photo/、/p/、/、/foo-bar/ 等）。物理文件始终在
# uploads/yyyy/mm/file，这两条规则把任何前缀的 /<prefix>/yyyy/mm/file
# 重写到 image.php?file=yyyy/mm/file，由 PHP 流式提供 + 累加 view_count
# （只有「启用图片请求计数」开关 ON 时才真的累加；否则只 serve 不计数）。
#
# 排除的前缀（保留为框架 / 直连路径，不走 PHP）：
#   uploads — 默认前缀，文件直接 serve（最快，无计数）
#   i       — 已经是 PHP 路由（/i/<file> 由 image.php 直接处理）
#   api / static / assets / data / logs — 框架路由，绝不能踩
#
# 同时支持「无前缀」直链：/yyyy/mm/file（前缀=根 "/"）→ 同样走 PHP
RewriteCond %{REQUEST_URI} !^/(uploads|i|api|static|assets|data|logs)/
RewriteRule ^[a-z0-9][a-z0-9_-]*/([0-9]{4}/[0-9]{2}/[^/]+\.(?:jpg|jpeg|png|gif|webp|avif|svg|ico|bmp|tiff|tif|heic|jxl|raw|dng))$ image.php?file=$1 [L,QSA]
RewriteRule ^([0-9]{4}/[0-9]{2}/[^/]+\.(?:jpg|jpeg|png|gif|webp|avif|svg|ico|bmp|tiff|tif|heic|jxl|raw|dng))$ image.php?file=$1 [L,QSA]
