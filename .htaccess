RewriteEngine On
DirectorySlash Off

# Modern image MIME types — Apache's default mime.types doesn't ship
# WebP/AVIF on every distro, so static delivery falls back to
# application/octet-stream which breaks <img> rendering and downloads.
<IfModule mod_mime.c>
    AddType image/webp .webp
    AddType image/avif .avif
    AddType image/apng .apng
</IfModule>

# 优先拦截 /api 路径（避免与 api/ 真实目录冲突）
RewriteRule ^api/?$ index.php [QSA,L]
RewriteRule ^api/v1(/.*)?$ index.php [QSA,L]
RewriteRule ^i(/.*)?$ index.php [QSA,L]

# 禁止访问敏感文件和目录
RedirectMatch 403 ^/\.env
RedirectMatch 403 ^/\.git
RedirectMatch 403 ^/data/
RedirectMatch 403 ^/logs/
<FilesMatch "^\.">
    Order allow,deny
    Deny from all
</FilesMatch>

# 禁止在 uploads 目录执行 PHP（即使上传了恶意脚本也无法执行）
<IfModule mod_rewrite.c>
    RewriteRule ^uploads/.*\.php$ - [F,L]

    # 可选：严格防盗链时取消注释，并改成你的域名
    # RewriteCond %{HTTP_REFERER} !^$
    # RewriteCond %{HTTP_REFERER} !^https?://([^/]+\.)?example\.com(/|$) [NC]
    # RewriteRule ^uploads/ - [F,L]
</IfModule>

# 真实文件/目录直接访问（/api 路径除外，需路由到单入口）
RewriteCond %{REQUEST_URI} !^/api/?$
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# 统一单入口无后缀路由
RewriteRule ^$ index.php [QSA,L]
RewriteRule ^(upload|gallery|docs|api|settings|stats)/?$ index.php [QSA,L]
RewriteRule ^i/.*$ index.php [QSA,L]
